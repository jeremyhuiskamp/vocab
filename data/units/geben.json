          "english": "I have to admit that I made a mistake."
        },
        {
          "fragments": [
            {
              "text": "Er ",
              "is_target": false
            },
            {
              "text": "gab",
              "is_target": true
            },
            {
              "text": " ",
              "is_target": false
            },
            {
              "text": "zu",
              "is_target": true
            },
            {
              "text": ", die Kekse gegessen zu haben.",
              "is_target": false
            }
