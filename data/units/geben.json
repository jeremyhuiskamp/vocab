          "english": "He admitted to having eaten the cookies."
        },
        {
          "fragments": [
            {
              "text": "Wirst du endlich ",
              "is_target": false
            },
            {
              "text": "zugeben",
              "is_target": true
            },
            {
              "text": ", wer es getan hat?",
              "is_target": false
            }
          ],
