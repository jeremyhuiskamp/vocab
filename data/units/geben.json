        {
          "fragments": [
            {
              "text": "Gib",
              "is_target": true
            },
            {
              "text": " doch einfach ",
              "is_target": false
            },
            {
              "text": "zu",
              "is_target": true
            },
            {
              "text": "! Es ist leichter.",
              "is_target": false
            }
          ],
          "english": "Just admit it! It's easier."
        }
      ]
    },
    {
      "word": "begeben",
      "target_language": "german",
      "sentences": [
        {
          "fragments": [
            {
              "text": "Wir müssen uns sofort zum Treffpunkt ",
